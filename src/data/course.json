        "emergency": [
          "选择困难：颜色+性格+小名",
          "孩子跑题：给 30 秒最终选择",
          "时间不足：只写最终名字"
        ]
      },
      "image": "/visuals/materials/real-device-hero.png",
      "imageAlt": "AI 桌宠实物图",
      "imageFit": "contain"
