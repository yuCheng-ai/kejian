{
  "meta": {
    "title": "OPC 亲子 AI 机器人唤醒营",
    "subtitle": "2 小时唤醒你的第一台 AI 桌宠机器人",
    "audience": "7-14 岁孩子与家长",
    "durationMinutes": 120,
    "host": "OPC 社区"
  },
  "slides": [
    {
      "id": 1,
      "title": "第 1 关：认识 AI 桌宠",
      "subtitle": "它会听、会看、会说，还会做表情",
      "visual": "systems",
      "accent": "cyan",
      "timerSeconds": 600,
      "student": {
        "headline": "它为什么像一个小伙伴？",
        "summary": "它有眼睛、耳朵、嘴巴和小脑袋，可以听你说话，也可以回答你。",
        "bullets": [
          "身体：屏幕和外壳",
          "耳朵：麦克风",
          "眼睛：摄像头",
          "嘴巴：喇叭"
        ],
        "activityTitle": "认识小伙伴",
        "activitySteps": [
          "看老师演示",
          "找找它的耳朵",
          "找找它的眼睛",
          "听听它怎么回答"
        ],
        "checkpoint": "你能说出它的 2 个小本领。",
        "callout": "先认识小伙伴。"
      },
      "teacher": {
        "estimatedMinutes": 10,
        "script": [
          "口令：今天我们不是只看机器人，而是要把一台 AI 桌宠唤醒、训练成自己的作品。",
          "演示口令：大家先不操作，只观察它怎么听、怎么看、怎么说、表情怎么变。"
        ],
        "actions": [
          "发任务卡",
          "演示一次唤醒和一句问答",
          "让孩子说出现象，不讲复杂原理",
          "提醒先不要插线"
        ],
        "notes": [
          "科普控制在 10 分钟内",
          "只讲身体、感官、AI 大脑三个词",
          "不要讲芯片型号和技术细节"
        ],
        "emergency": [
          "样机失败：放本地录屏",
          "孩子太兴奋：回到规则，听口令再动手",
          "低龄孩子听不懂：只讲耳朵、眼睛、嘴巴"
        ]
      },
      "image": "/visuals/materials/real-device-hero.png",
      "imageAlt": "白色 AI 桌宠实物图",
      "imageFit": "contain"
    },
    {
      "id": 2,
      "title": "第 2 关：认识小零件",
      "subtitle": "找到屏幕、摄像头、麦克风、喇叭和接口",
      "visual": "parts",
      "accent": "green",
      "timerSeconds": 720,
      "student": {
        "headline": "桌宠身体里藏着什么？",
        "summary": "先用眼睛找一找。找到这些小零件，后面动手就不慌。",
        "bullets": [
          "屏幕",
          "摄像头",
          "麦克风",
          "喇叭",
          "充电口",
          "外壳"
        ],
        "activityTitle": "找零件",
        "activitySteps": [
          "把材料摆整齐",
          "找到屏幕",
          "找到小镜头",
          "找到插线口"
        ],
        "checkpoint": "你能指出 4 个小零件。",
        "callout": "先找一找。"
      },
      "teacher": {
        "estimatedMinutes": 12,
        "script": [
          "口令：现在观察真实物料。孩子只指认，不拔线、不拆壳、不插电。"
        ],
        "actions": [
          "举起实物示范",
          "按屏幕、摄像头、麦克风、喇叭、接口顺序点名",
          "助教巡视纠正",
          "缺件组举手"
        ],
        "notes": [
          "学生记功能词，不背型号",
          "摄像头和麦克风用眼睛耳朵比喻",
          "家长可以指认，但不代替孩子操作"
        ],
        "emergency": [
          "缺件：助教补发",
          "孩子拔线：立即停手复位",
          "材料混组：按组号重新核对"
        ]
      },
      "image": "/visuals/materials/real-parts-kit.png",
      "imageAlt": "AI 桌宠外壳、屏幕、控制板和线材物料图",
      "imageFit": "contain",
      "supportImages": [
        {
          "src": "/visuals/materials/real-product-gallery.png",
          "label": "实物展示"
        },
        {
          "src": "/visuals/materials/real-board-annotated.png",
          "label": "部件标注"
        }
      ]
    },
    {
      "id": 3,
      "title": "第 3 关：准备装程序",
      "subtitle": "确认组号、接口和数据线，等老师口令",
      "visual": "chip",
      "accent": "orange",
      "timerSeconds": 480,
      "student": {
        "headline": "先排好队，别急着点",
        "summary": "我们要把小程序装进桌宠。听老师口令，一步一步来。",
        "bullets": [
          "看组号",
          "检查线",
          "找插口",
          "等口令"
        ],
        "activityTitle": "准备出发",
        "activitySteps": [
          "看自己的组号",
          "拿好数据线",
          "找到插线口",
          "小手等一等"
        ],
        "checkpoint": "你已经准备好线、组号和插口。",
        "callout": "先准备好。"
      },
      "teacher": {
        "estimatedMinutes": 8,
        "script": [
          "口令：烧录就是把唤醒程序装进机器人。现在只准备，不抢跑，等老师说开始。"
        ],
        "actions": [
          "打开一键烧录工具",
          "按组号或座位分批",
          "确认数据线是可传输线",
          "白板写失败举手规则"
        ],
        "notes": [
          "学生屏可以说烧录，但不讲驱动、串口、编译",
          "不要让全场同时乱点",
          "低龄组由家长扶线，孩子点击"
        ],
        "emergency": [
          "识别不到：换线或换 USB 口",
          "电脑少：老师统一烧录",
          "等待组：继续填写名字候选"
        ]
      },
      "image": "/visuals/materials/real-device-wireless.png",
      "imageAlt": "AI 桌宠连接能力示意图",
      "imageFit": "contain"
    },
    {
      "id": 4,
      "title": "第 4 关：叫醒小桌宠",
      "subtitle": "看到完成，再插线开机，等 3 秒",
      "visual": "power",
      "accent": "yellow",
      "timerSeconds": 900,
      "student": {
        "headline": "它要第一次醒来了",
        "summary": "点一下开始，然后安静等。完成后插线，看它给你的第一个反应。",
        "bullets": [
          "点击开始",
          "看到完成",
          "插线开机",
          "发现变化"
        ],
        "activityTitle": "叫醒步骤",
        "activitySteps": [
          "点击开始",
          "看到完成就举手",
          "插线后数 3 秒",
          "写下第一个变化"
        ],
        "checkpoint": "它亮了、响了，或者屏幕动起来了。",
        "callout": "准备叫醒它。"
      },
      "teacher": {
        "estimatedMinutes": 15,
        "script": [
          "口令：现在开始装入唤醒程序。看到绿色完成后举手，失败不要自己反复点。",
          "口令：成功组第一次开机。插线后等 3 秒，只看灯、屏幕和声音。"
        ],
        "actions": [
          "分批点击烧录",
          "成功组白板打勾",
          "统一口令插线开机",
          "让孩子写下第一个变化"
        ],
        "notes": [
          "这是第一个高潮点，节奏要稳",
          "失败组快速换线或换备用板",
          "不让孩子连续按按钮"
        ],
        "emergency": [
          "烧录失败：重试一次后换备用板",
          "反复重启：换电源",
          "发热异常：立即断电换设备"
        ]
      },
      "image": "/visuals/materials/real-device-hero.png",
      "imageAlt": "AI 桌宠实物亮屏图",
      "imageFit": "contain"
    },
    {
      "id": 5,
      "title": "第 5 关：说第一句话",
      "subtitle": "联网后只说一句短话",
      "visual": "cloud",
      "accent": "green",
      "timerSeconds": 720,
      "student": {
        "headline": "和它打个招呼",
        "summary": "轮到你时，说一句短短的话。听到回答后，记下一个你喜欢的词。",
        "bullets": [
          "连上网",
          "等提示",
          "说短话",
          "记一个词"
