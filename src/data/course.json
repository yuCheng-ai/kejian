        "emergency": [
          "联网波动：展示预设回答",
          "孩子紧张：家长举设备，孩子读任务卡",
          "时间不足：只做介绍自己"
        ]
      },
      "image": "/visuals/materials/real-device-hero.png",
      "imageAlt": "AI 桌宠实物图",
      "imageFit": "contain"
