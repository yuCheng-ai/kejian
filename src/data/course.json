      "teacher": {
        "estimatedMinutes": 8,
        "script": [
          "口令：现在给机器人起名字。名字短一点、清楚一点，写 3 个候选名，再选一个最喜欢的。"
        ],
        "actions": [
          "计时 2 分钟",
          "邀请 2-3 组分享",
          "提醒贴到任务卡",
          "家长拍任务卡"
