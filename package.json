{
  "name": "opc-ai-robot-salon-courseware",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,sync -c cyan,green \"npm:dev:web\" \"npm:sync\"",
    "dev:web": "vite --host 0.0.0.0",
    "sync": "node server/sync-server.mjs",
    "build": "tsc -b && vite build",
    "preview": "concurrently -k -n web,sync -c cyan,green \"vite preview --host 0.0.0.0\" \"npm:sync\""
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
